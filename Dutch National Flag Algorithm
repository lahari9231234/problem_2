class Solution:
    # Function to sort array containing 0s, 1s, and 2s
    def sort_zero_one_two(self, nums):
        low = 0
        mid = 0
        high = len(nums) - 1

        # Process until mid crosses high
        while mid <= high:

            # If element is 0
            if nums[mid] == 0:
                nums[mid], nums[low] = nums[low], nums[mid]
                low += 1
                mid += 1

            # If element is 1
            elif nums[mid] == 1:
                mid += 1

            # If element is 2
            else:
                nums[mid], nums[high] = nums[high], nums[mid]
                high -= 1


